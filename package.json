{
  "name": "peaceful-haven-estimator",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node ./node_modules/typescript/bin/tsc -b && node ./node_modules/vite/bin/vite.js build",
    "preview": "vite preview",
    "postinstall": "node -e \"const fs=require('fs');const p='node_modules/@esbuild/linux-x64/bin/esbuild';if(fs.existsSync(p)){fs.chmodSync(p,0o755);console.log('Ensured executable permission for '+p);}\""
  },
  "dependencies": {
    "framer-motion": "^12.23.12",
    "jspdf": "^3.0.3",
    "lucide-react": "^0.542.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.2",
    "typescript": "^5.9.2",
    "vite": "^7.1.3"
  }
}
