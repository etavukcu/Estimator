# Required for server/API-based email delivery
RESEND_API_KEY=re_123456789

# Optional: custom sender (must be verified in your email provider)
EMAIL_FROM="Peaceful Haven Estimator <estimates@peacefulhavenhomes.com>"

# Optional for local client development against the API server
VITE_API_BASE_URL=http://localhost:8787

# Required for Supabase lead capture via the server API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional fallback for client-side direct Supabase writes (used if API endpoint is unavailable)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
