# Required for server/API-based email delivery
RESEND_API_KEY=re_123456789

# Optional: custom sender (must be verified in your email provider)
EMAIL_FROM="Peaceful Haven Estimator <estimates@peacefulhavenhomes.com>"

# Required for client-side Supabase lead capture
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional: route submissions through a custom API server (instead of direct client insert)
VITE_API_BASE_URL=http://localhost:8787

# Optional for server-hosted API mode only
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
